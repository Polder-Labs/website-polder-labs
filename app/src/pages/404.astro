---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base title="Pagina niet gevonden | Polder Labs" description="De opgevraagde pagina bestaat niet.">
	<section class="section">
		<div class="container" style="text-align: center;">
			<h1>Pagina niet gevonden</h1>
			<p style="margin: var(--space-3) auto 0; color: var(--color-text-secondary);">
				De pagina die u zoekt bestaat niet of is verplaatst.
			</p>
			<div style="margin-top: var(--space-4); display: flex; justify-content: center;">
				<a href="/" class="btn btn--primary">Terug naar home</a>
			</div>
		</div>
	</section>
</Base>
